# B0 — vanilla vLLM v1 (FCFS scheduling, no KV optimization). Serve-time knobs.
# Values mirror configs/model.yaml (the source of truth). Conditional (`:=`)
# assignment means anything already set in the environment WINS, so overrides
# work, e.g.  `PORT=8001 serving/serve_b0.sh`  or the smoke line below.

: "${MODEL:=meta-llama/Llama-3.1-8B-Instruct}"
: "${DTYPE:=float16}"
: "${MAX_MODEL_LEN:=8192}"
: "${GPU_MEM_UTIL:=0.90}"
: "${SEED:=0}"
: "${HOST:=127.0.0.1}"
: "${PORT:=8000}"

# --- RTX 3090 (24 GB) local-dev notes ---
# Llama-3.1-8B FP16 ~= 16 GB weights; 0.90 * 24 GB ~= 21.6 GB usable ->
# ~5.6 GB KV headroom. max_model_len 8192 fits. If you OOM at load time:
#   - drop MAX_MODEL_LEN to 4096, or
#   - drop GPU_MEM_UTIL to 0.88.
# Fast pipeline smoke test with the open 0.5B model:
#   MODEL=Qwen/Qwen2.5-0.5B-Instruct MAX_MODEL_LEN=4096 serving/serve_b0.sh
