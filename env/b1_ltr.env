# B1 — LTR-scheduled vLLM v1 (reproduce the prior paper's ~2.1x over FCFS).
# Same model/dtype/ctx as B0; the scheduler is priority-driven by the ranker.
# Conditional (:=) assignment so environment overrides win.

: "${MODEL:=meta-llama/Llama-3.1-8B-Instruct}"
: "${DTYPE:=float16}"
: "${MAX_MODEL_LEN:=8192}"
: "${GPU_MEM_UTIL:=0.90}"
: "${SEED:=0}"
: "${HOST:=127.0.0.1}"
: "${PORT:=8000}"

# Trained OPT-125M ranker, used CLIENT-SIDE by the harness to assign each
# request's `priority` (vLLM serves with --scheduling-policy priority).
# Train it with:  python -m ltr.ranker.train --out "$RANKER_PATH"
: "${RANKER_PATH:=results/ranker/opt125m-ltr}"

# --- RTX 3090 local dev ---
# Llama-8B is memory-tight/unstable on a single 24GB card under WSL2; use the
# proposal's 3090 model instead:
#   MODEL=Qwen/Qwen2.5-3B-Instruct GPU_MEM_UTIL=0.55 serving/serve_b1_ltr.sh
